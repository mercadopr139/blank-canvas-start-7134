# Environment variables — never commit secrets
.env
.env.local
.env.*.local

# Data export/import files — contain real user data, never commit
scripts/*.json
scripts/*.sql

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Supabase CLI scratch — machine-specific, regenerated per-link
supabase/.temp/

# Claude Code agent worktrees — temporary checkouts, never commit
.claude/worktrees/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
