# Two env files are used in this project:
#
#   .env       — Supabase publishable values needed by the Vite build. Lives
#                in git for now so the Vercel deploy keeps working. Do NOT
#                add secrets here.
#
#   .env.local — Real secrets and dev overrides. Gitignored. Used by
#                one-off /scripts via `node --env-file=.env.local …`.
#
# Copy this file to whichever you need, then fill in real values.

# ─── .env (committed, public-safe values only) ────────────────────────────
# Supabase — find these in Project Settings → API on the Supabase dashboard.
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxx"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# ─── .env.local (gitignored, secrets only) ────────────────────────────────
# Monday.com — only needed for one-off backfill scripts in /scripts.
# Generate at: monday.com → avatar → Developers → My Access Tokens.
# Treat like a password. Rotate after running backfill jobs.
MONDAY_API_TOKEN=""
MONDAY_BOARD_ID=""
